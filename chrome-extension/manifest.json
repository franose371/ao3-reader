{
  "manifest_version": 3,
  "name": "AO3 Reader",
  "version": "1.1.0",
  "description": "优化AO3网站在手机端的阅读体验，支持左右点击翻页的分页阅读模式",
  "permissions": ["storage"],
  "host_permissions": ["https://archiveofourown.org/*"],
  "content_scripts": [
    {
      "matches": ["https://archiveofourown.org/works/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AO3 Reader - 阅读设置"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
